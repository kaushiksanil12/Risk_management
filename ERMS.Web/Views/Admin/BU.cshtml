@{ ViewData["Title"] = "Business Units"; }
<div class="d-flex justify-content-between align-items-center mb-4"><h5 class="mb-0">Business Units</h5><button class="btn btn-primary rounded-pill" onclick="openBUModal()"><i class="bi bi-plus-lg me-1"></i>Add BU</button></div>
<div class="card mb-4"><div class="card-body"><div class="row g-2 align-items-end"><div class="col-md-4"><input type="text" class="form-control" id="searchBU" placeholder="Search..."/></div><div class="col-md-3"><select class="form-select" id="statusFilter"><option value="">All</option><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div><div class="col-md-2"><button class="btn btn-outline-primary w-100" onclick="loadBUs()"><i class="bi bi-search me-1"></i>Search</button></div></div></div></div>
<div class="card"><div class="card-body"><div class="table-responsive"><table class="table table-hover"><thead><tr><th>BU ID</th><th>BU Name</th><th>Short Name</th><th>Status</th><th>Actions</th></tr></thead><tbody id="buTableBody"><tr><td colspan="5" class="text-center text-muted">Loading...</td></tr></tbody></table></div></div></div>
<div class="modal fade" id="buModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title" id="buModalTitle">Add Business Unit</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><input type="hidden" id="editBUId"/><div class="mb-3"><label class="form-label">BU Name</label><input type="text" class="form-control" id="fBUName"/></div><div class="mb-3"><label class="form-label">Short Name</label><input type="text" class="form-control" id="fBUShortName"/></div><div class="mb-3"><label class="form-label">Status</label><select class="form-select" id="fBUStatus"><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="button" class="btn btn-primary" onclick="saveBU()">Save</button></div></div></div></div>
@section scripts {
<script>
function loadBUs(){const s=document.getElementById('searchBU').value,st=document.getElementById('statusFilter').value;apiCall('GET',`/api/bu/search?search=${encodeURIComponent(s)}&status=${encodeURIComponent(st)}`).then(r=>{const tb=document.getElementById('buTableBody');if(!r.success||!r.data||r.data.length===0){tb.innerHTML='<tr><td colspan="5" class="text-center text-muted">No records</td></tr>';return}tb.innerHTML=r.data.map(b=>`<tr><td>${b.buId}</td><td>${b.buName}</td><td>${b.buShortName}</td><td><span class="badge ${b.status==='Active'?'bg-success':'bg-secondary'} rounded-pill">${b.status}</span></td><td><button class="btn btn-sm btn-outline-primary" onclick="editBU('${b.buId}')"><i class="bi bi-pencil"></i></button></td></tr>`).join('')})}
function openBUModal(){document.getElementById('editBUId').value='';document.getElementById('buModalTitle').textContent='Add Business Unit';document.getElementById('fBUName').value='';document.getElementById('fBUShortName').value='';document.getElementById('fBUStatus').value='Active';new bootstrap.Modal(document.getElementById('buModal')).show()}
function editBU(id){apiCall('GET',`/api/bu/${id}`).then(r=>{if(!r.success){showToast(r.message,'danger');return}const b=r.data;document.getElementById('editBUId').value=b.buId;document.getElementById('buModalTitle').textContent='Edit Business Unit';document.getElementById('fBUName').value=b.buName;document.getElementById('fBUShortName').value=b.buShortName;document.getElementById('fBUStatus').value=b.status;new bootstrap.Modal(document.getElementById('buModal')).show()})}
function saveBU(){const id=document.getElementById('editBUId').value;const body={buName:document.getElementById('fBUName').value,buShortName:document.getElementById('fBUShortName').value,status:document.getElementById('fBUStatus').value};const url=id?`/api/bu/update/${id}`:'/api/bu/create';apiCall(id?'PUT':'POST',url,body).then(r=>{showToast(r.message,r.success?'success':'danger');if(r.success){bootstrap.Modal.getInstance(document.getElementById('buModal')).hide();loadBUs()}})}
document.addEventListener('DOMContentLoaded',loadBUs);
</script>}
