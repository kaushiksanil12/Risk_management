@{ ViewData["Title"] = "Functions"; }
<div class="d-flex justify-content-between align-items-center mb-4"><h5 class="mb-0">Functions</h5><button class="btn btn-primary rounded-pill" onclick="openFnModal()"><i class="bi bi-plus-lg me-1"></i>Add Function</button></div>
<div class="card mb-4"><div class="card-body"><div class="row g-2 align-items-end"><div class="col-md-4"><input type="text" class="form-control" id="searchFn" placeholder="Search..."/></div><div class="col-md-3"><select class="form-select" id="statusFilter"><option value="">All</option><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div><div class="col-md-2"><button class="btn btn-outline-primary w-100" onclick="loadFns()"><i class="bi bi-search me-1"></i>Search</button></div></div></div></div>
<div class="card"><div class="card-body"><div class="table-responsive"><table class="table table-hover"><thead><tr><th>ID</th><th>Function Name</th><th>Status</th><th>Actions</th></tr></thead><tbody id="fnTableBody"><tr><td colspan="4" class="text-center text-muted">Loading...</td></tr></tbody></table></div></div></div>
<div class="modal fade" id="fnModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title" id="fnModalTitle">Add Function</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><input type="hidden" id="editFnId"/><div class="mb-3"><label class="form-label">Function Name</label><input type="text" class="form-control" id="fFnName"/></div><div class="mb-3"><label class="form-label">Status</label><select class="form-select" id="fFnStatus"><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div></div><div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" onclick="saveFn()">Save</button></div></div></div></div>
@section scripts {
<script>
function loadFns(){const s=document.getElementById('searchFn').value,st=document.getElementById('statusFilter').value;apiCall('GET',`/api/function/search?search=${encodeURIComponent(s)}&status=${encodeURIComponent(st)}`).then(r=>{const tb=document.getElementById('fnTableBody');if(!r.success||!r.data?.length){tb.innerHTML='<tr><td colspan="4" class="text-center">No functions found</td></tr>';return}tb.innerHTML=r.data.map(f=>`<tr><td>${f.functionId}</td><td>${f.functionName}</td><td><span class="badge ${f.status==='Active'?'bg-success':'bg-secondary'} rounded-pill">${f.status}</span></td><td><button class="btn btn-sm btn-outline-primary" onclick="editFn(${f.functionId})"><i class="bi bi-pencil"></i></button></td></tr>`).join('')})}
function openFnModal(){document.getElementById('editFnId').value='';document.getElementById('fnModalTitle').textContent='Add Function';document.getElementById('fFnName').value='';document.getElementById('fFnStatus').value='Active';new bootstrap.Modal(document.getElementById('fnModal')).show()}
function editFn(id){apiCall('GET',`/api/function/${id}`).then(r=>{if(!r.success)return;const f=r.data;document.getElementById('editFnId').value=f.functionId;document.getElementById('fnModalTitle').textContent='Edit Function';document.getElementById('fFnName').value=f.functionName;document.getElementById('fFnStatus').value=f.status;new bootstrap.Modal(document.getElementById('fnModal')).show()})}
function saveFn(){const id=document.getElementById('editFnId').value;const body={functionName:document.getElementById('fFnName').value,status:document.getElementById('fFnStatus').value};apiCall(id?'PUT':'POST',id?`/api/function/update/${id}`:'/api/function/create',body).then(r=>{showToast(r.message,r.success?'success':'danger');if(r.success){bootstrap.Modal.getInstance(document.getElementById('fnModal')).hide();loadFns()}})}
document.addEventListener('DOMContentLoaded',loadFns);
</script>}
