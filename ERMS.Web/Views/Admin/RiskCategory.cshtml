@{ ViewData["Title"] = "Risk Categories"; }
<div class="d-flex justify-content-between align-items-center mb-4"><h5 class="mb-0">Risk Categories & Sub-Categories</h5><button class="btn btn-primary rounded-pill" onclick="openCatModal()"><i class="bi bi-plus-lg me-1"></i>Add Category</button></div>
<div class="row g-4">
<div class="col-md-5">
    <div class="card"><div class="card-header"><h6 class="mb-0">Categories</h6></div><div class="card-body"><div class="table-responsive"><table class="table table-hover"><thead><tr><th>Name</th><th>Alias</th><th>Status</th><th>Actions</th></tr></thead><tbody id="catBody"><tr><td colspan="4" class="text-center text-muted">Loading...</td></tr></tbody></table></div></div></div>
</div>
<div class="col-md-7">
    <div class="card"><div class="card-header d-flex justify-content-between"><h6 class="mb-0" id="subCatTitle">Sub-Categories</h6><button class="btn btn-sm btn-primary rounded-pill" onclick="openSubCatModal()" id="btnAddSub" style="display:none"><i class="bi bi-plus-lg me-1"></i>Add</button></div><div class="card-body"><div class="table-responsive"><table class="table table-hover"><thead><tr><th>Name</th><th>Alias</th><th>Status</th><th>Actions</th></tr></thead><tbody id="subCatBody"><tr><td colspan="4" class="text-center text-muted">Select a category</td></tr></tbody></table></div></div></div>
</div></div>

<div class="modal fade" id="catModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title" id="catModalTitle">Add Category</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><input type="hidden" id="editCatId"/><div class="mb-3"><label class="form-label">Category Name</label><input type="text" class="form-control" id="fCatName"/></div><div class="mb-3"><label class="form-label">Alias</label><input type="text" class="form-control" id="fCatAlias"/></div><div class="mb-3"><label class="form-label">Status</label><select class="form-select" id="fCatStatus"><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div></div><div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" onclick="saveCat()">Save</button></div></div></div></div>

<div class="modal fade" id="subCatModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title" id="subCatModalTitle">Add Sub-Category</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><input type="hidden" id="editSubCatId"/><div class="mb-3"><label class="form-label">Sub-Category Name</label><input type="text" class="form-control" id="fSubCatName"/></div><div class="mb-3"><label class="form-label">Alias</label><input type="text" class="form-control" id="fSubCatAlias"/></div><div class="mb-3"><label class="form-label">Status</label><select class="form-select" id="fSubCatStatus"><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div></div><div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" onclick="saveSubCat()">Save</button></div></div></div></div>

@section scripts {
<script>
let selectedCatId = null;
function loadCats(){apiCall('GET','/api/riskcategory/search?search=&status=').then(r=>{const tb=document.getElementById('catBody');if(!r.success||!r.data?.length){tb.innerHTML='<tr><td colspan="4" class="text-center">No categories</td></tr>';return}tb.innerHTML=r.data.map(c=>`<tr class="${selectedCatId===c.riskCatId?'table-active':''}" style="cursor:pointer" onclick="selectCat(${c.riskCatId})"><td>${c.riskCatName}</td><td>${c.riskCatAlias}</td><td><span class="badge ${c.status==='Active'?'bg-success':'bg-secondary'} rounded-pill">${c.status}</span></td><td><button class="btn btn-sm btn-outline-primary" onclick="event.stopPropagation();editCat(${c.riskCatId})"><i class="bi bi-pencil"></i></button></td></tr>`).join('')})}
function selectCat(id){selectedCatId=id;document.getElementById('btnAddSub').style.display='';document.getElementById('subCatTitle').textContent='Sub-Categories';loadSubCats();loadCats()}
function loadSubCats(){if(!selectedCatId)return;apiCall('GET',`/api/risksubcategory/search?riskCatId=${selectedCatId}&search=&status=`).then(r=>{const tb=document.getElementById('subCatBody');if(!r.success||!r.data?.length){tb.innerHTML='<tr><td colspan="4" class="text-center">No sub-categories</td></tr>';return}tb.innerHTML=r.data.map(s=>`<tr><td>${s.riskSubCatName}</td><td>${s.riskCatAlias||''}</td><td><span class="badge ${s.status==='Active'?'bg-success':'bg-secondary'} rounded-pill">${s.status}</span></td><td><button class="btn btn-sm btn-outline-primary" onclick="editSubCat(${s.riskSubCatId})"><i class="bi bi-pencil"></i></button></td></tr>`).join('')})}
function openCatModal(){document.getElementById('editCatId').value='';document.getElementById('catModalTitle').textContent='Add Category';document.getElementById('fCatName').value='';document.getElementById('fCatAlias').value='';document.getElementById('fCatStatus').value='Active';new bootstrap.Modal(document.getElementById('catModal')).show()}
function editCat(id){apiCall('GET',`/api/riskcategory/${id}`).then(r=>{if(!r.success)return;const c=r.data;document.getElementById('editCatId').value=c.riskCatId;document.getElementById('catModalTitle').textContent='Edit Category';document.getElementById('fCatName').value=c.riskCatName;document.getElementById('fCatAlias').value=c.riskCatAlias;document.getElementById('fCatStatus').value=c.status;new bootstrap.Modal(document.getElementById('catModal')).show()})}
function saveCat(){const id=document.getElementById('editCatId').value;const body={riskCatName:document.getElementById('fCatName').value,riskCatAlias:document.getElementById('fCatAlias').value,status:document.getElementById('fCatStatus').value};apiCall(id?'PUT':'POST',id?`/api/riskcategory/update/${id}`:'/api/riskcategory/create',body).then(r=>{showToast(r.message,r.success?'success':'danger');if(r.success){bootstrap.Modal.getInstance(document.getElementById('catModal')).hide();loadCats()}})}
function openSubCatModal(){document.getElementById('editSubCatId').value='';document.getElementById('subCatModalTitle').textContent='Add Sub-Category';document.getElementById('fSubCatName').value='';document.getElementById('fSubCatAlias').value='';document.getElementById('fSubCatStatus').value='Active';new bootstrap.Modal(document.getElementById('subCatModal')).show()}
function editSubCat(id){apiCall('GET',`/api/risksubcategory/${id}`).then(r=>{if(!r.success)return;const s=r.data;document.getElementById('editSubCatId').value=s.riskSubCatId;document.getElementById('subCatModalTitle').textContent='Edit Sub-Category';document.getElementById('fSubCatName').value=s.riskSubCatName;document.getElementById('fSubCatAlias').value=s.riskCatAlias||'';document.getElementById('fSubCatStatus').value=s.status;new bootstrap.Modal(document.getElementById('subCatModal')).show()})}
function saveSubCat(){const id=document.getElementById('editSubCatId').value;const body={riskCatId:selectedCatId,riskSubCatName:document.getElementById('fSubCatName').value,riskCatAlias:document.getElementById('fSubCatAlias').value,status:document.getElementById('fSubCatStatus').value};apiCall(id?'PUT':'POST',id?`/api/risksubcategory/update/${id}`:'/api/risksubcategory/create',body).then(r=>{showToast(r.message,r.success?'success':'danger');if(r.success){bootstrap.Modal.getInstance(document.getElementById('subCatModal')).hide();loadSubCats()}})}
document.addEventListener('DOMContentLoaded',loadCats);
</script>}
