@{ ViewData["Title"] = "Create New Risk"; }
<div class="mb-4"><a href="/Risk/Index" class="btn btn-outline-secondary rounded-pill"><i class="bi bi-arrow-left me-1"></i>Back to Risks</a></div>
<div class="card"><div class="card-header"><h5 class="mb-0">New Risk Entry</h5></div><div class="card-body">
    <div class="row g-3">
        <div class="col-md-4"><label class="form-label">Business Unit</label><select class="form-select" id="fBU"></select></div>
        <div class="col-md-4"><label class="form-label">Financial Year</label><select class="form-select" id="fFY"></select></div>
        <div class="col-md-4"><label class="form-label">Risk Category</label><select class="form-select" id="fCat" onchange="loadSubCats()"></select></div>
        <div class="col-md-4"><label class="form-label">Sub-Category</label><select class="form-select" id="fSubCat"></select></div>
        <div class="col-md-4"><label class="form-label">Function</label><select class="form-select" id="fFunc"></select></div>
        <div class="col-md-4"><label class="form-label">Impact Level</label><select class="form-select" id="fImpact"><option>High</option><option selected>Medium</option><option>Low</option></select></div>
        <div class="col-md-4"><label class="form-label">Likelihood</label><select class="form-select" id="fLike"><option>High</option><option selected>Medium</option><option>Low</option></select></div>
        <div class="col-12"><label class="form-label">Risk Title</label><input type="text" class="form-control" id="fTitle" maxlength="200"/></div>
        <div class="col-12"><label class="form-label">Description <small class="text-muted">(min 20 characters)</small></label><textarea class="form-control" id="fDesc" rows="4"></textarea></div>
        <div class="col-12"><button class="btn btn-primary rounded-pill me-2" onclick="saveRisk()"><i class="bi bi-save me-1"></i>Save Draft</button><button class="btn btn-success rounded-pill" onclick="saveAndSubmit()"><i class="bi bi-send me-1"></i>Save & Submit</button></div>
    </div>
</div></div>
@section scripts {
<script>
function loadDropdowns(){apiCall('GET','/api/bu/dropdown').then(r=>{if(r.success)r.data.forEach(d=>{const o=document.createElement('option');o.value=d.value;o.text=d.text;document.getElementById('fBU').appendChild(o)})});apiCall('GET','/api/permission/fy/dropdown').then(r=>{if(r.success)r.data.forEach(d=>{const o=document.createElement('option');o.value=d.value;o.text=d.text;document.getElementById('fFY').appendChild(o)})});apiCall('GET','/api/riskcategory/dropdown').then(r=>{if(r.success)r.data.forEach(d=>{const o=document.createElement('option');o.value=d.riskCatId;o.text=d.riskCatName;document.getElementById('fCat').appendChild(o)})});apiCall('GET','/api/function/dropdown').then(r=>{if(r.success)r.data.forEach(d=>{const o=document.createElement('option');o.value=d.value;o.text=d.text;document.getElementById('fFunc').appendChild(o)})})}
function loadSubCats(){const catId=document.getElementById('fCat').value;const sub=document.getElementById('fSubCat');sub.innerHTML='<option value="">-- Select Sub-Category --</option>';if(!catId||catId==='0'||catId===''){return;}apiCall('GET',`/api/risksubcategory/dropdown?riskCatId=${catId}&mode=ACTIVE`).then(r=>{if(r.success&&r.data&&r.data.length>0){r.data.forEach(d=>{const o=document.createElement('option');o.value=d.riskSubCatId ?? d.RiskSubCatId ?? d.value;o.text=d.riskSubCatName ?? d.RiskSubCatName ?? d.text;sub.appendChild(o)})}else{sub.innerHTML='<option value="">No sub-categories available</option>';}})}
function getBody(){return{buId:document.getElementById('fBU').value,fyId:document.getElementById('fFY').value,riskCatId:parseInt(document.getElementById('fCat').value)||0,riskSubCatId:parseInt(document.getElementById('fSubCat').value)||0,functionId:parseInt(document.getElementById('fFunc').value)||0,riskTitle:document.getElementById('fTitle').value,description:document.getElementById('fDesc').value,impactLevel:document.getElementById('fImpact').value,likelihood:document.getElementById('fLike').value}}
function saveRisk(){apiCall('POST','/api/risk/create',getBody()).then(r=>{showToast(r.message,r.success?'success':'danger');if(r.success)window.location.href='/Risk/Index'})}
function saveAndSubmit(){apiCall('POST','/api/risk/create',getBody()).then(r=>{if(!r.success){showToast(r.message,'danger');return}const riskId=r.data;apiCall('POST',`/api/risk/submit/${riskId}`).then(r2=>{showToast(r2.message,r2.success?'success':'danger');if(r2.success)window.location.href='/Risk/Index'})})}
document.addEventListener('DOMContentLoaded',loadDropdowns);
</script>}
