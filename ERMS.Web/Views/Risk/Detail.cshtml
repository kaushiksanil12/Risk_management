@{ ViewData["Title"] = "Risk Details"; var riskId = ViewData["RiskId"]; }
<div class="mb-4"><a href="/Risk/Index" class="btn btn-outline-secondary rounded-pill"><i class="bi bi-arrow-left me-1"></i>Back</a></div>
<div class="row g-4">
<div class="col-lg-8">
    <div class="card mb-4"><div class="card-header d-flex justify-content-between align-items-center"><h5 class="mb-0" id="riskTitle">Loading...</h5><span class="badge rounded-pill" id="statusBadge"></span></div><div class="card-body">
        <div class="row g-3">
            <div class="col-md-4"><strong>BU:</strong><br/><span id="dBU">-</span></div>
            <div class="col-md-4"><strong>FY:</strong><br/><span id="dFY">-</span></div>
            <div class="col-md-4"><strong>Category:</strong><br/><span id="dCat">-</span></div>
            <div class="col-md-4"><strong>Sub-Category:</strong><br/><span id="dSubCat">-</span></div>
            <div class="col-md-4"><strong>Function:</strong><br/><span id="dFunc">-</span></div>
            <div class="col-md-4"><strong>Impact / Likelihood:</strong><br/><span id="dImpact" class="badge"></span> / <span id="dLike" class="badge"></span></div>
            <div class="col-12"><strong>Description:</strong><br/><p id="dDesc" class="mt-1">-</p></div>
            <div class="col-md-6"><strong>Created by:</strong><br/><span id="dCreatedBy">-</span></div>
            <div class="col-md-6"><strong>Reviewed by:</strong><br/><span id="dReviewedBy">-</span></div>
        </div>
    </div></div>
    <div class="card"><div class="card-header"><h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>History Timeline</h6></div><div class="card-body" id="historyBody"><p class="text-muted">Loading...</p></div></div>
</div>
<div class="col-lg-4">
    <div class="card mb-4" id="actionsCard"><div class="card-header"><h6 class="mb-0">Actions</h6></div><div class="card-body" id="actionsBody"></div></div>
    <div class="card" id="reviewCard" style="display:none"><div class="card-header"><h6 class="mb-0">Review</h6></div><div class="card-body">
        <div class="mb-3"><label class="form-label">Remarks</label><textarea class="form-control" id="rRemarks" rows="3"></textarea></div>
        <button class="btn btn-success btn-sm rounded-pill me-1" onclick="review('Approve')"><i class="bi bi-check-lg me-1"></i>Approve</button>
        <button class="btn btn-warning btn-sm rounded-pill me-1" onclick="review('SendBack')"><i class="bi bi-arrow-return-left me-1"></i>Send Back</button>
        <button class="btn btn-danger btn-sm rounded-pill" onclick="review('Reject')"><i class="bi bi-x-lg me-1"></i>Reject</button>
    </div></div>
</div></div>
@section scripts {
<script>
const riskId = @riskId;
const isAdmin = '@Context.Session.GetString("AdminFlag")' === 'Y';
const impactBadge={'High':'bg-danger','Medium':'bg-warning text-dark','Low':'bg-success'};
const statusBadge={'Draft':'bg-secondary','Submitted':'bg-primary','UnderReview':'bg-info','Approved':'bg-success','Rejected':'bg-danger','RevisionRequired':'bg-warning text-dark','Closed':'bg-dark'};
function loadRisk(){apiCall('GET',`/api/risk/${riskId}`).then(r=>{if(!r.success){showToast(r.message,'danger');return}const k=r.data;document.getElementById('riskTitle').textContent=`#${k.riskId} - ${k.riskTitle}`;const sb=document.getElementById('statusBadge');sb.textContent=k.status;sb.className=`badge rounded-pill ${statusBadge[k.status]||'bg-secondary'}`;document.getElementById('dBU').textContent=k.buName||k.buId;document.getElementById('dFY').textContent=k.fyName||k.fyId;document.getElementById('dCat').textContent=k.riskCatName;document.getElementById('dSubCat').textContent=k.riskSubCatName;document.getElementById('dFunc').textContent=k.functionName;const imp=document.getElementById('dImpact');imp.textContent=k.impactLevel;imp.className=`badge ${impactBadge[k.impactLevel]||'bg-secondary'} rounded-pill`;const like=document.getElementById('dLike');like.textContent=k.likelihood;like.className=`badge ${impactBadge[k.likelihood]||'bg-secondary'} rounded-pill`;document.getElementById('dDesc').textContent=k.description;document.getElementById('dCreatedBy').textContent=k.createdByName||'Unknown';document.getElementById('dReviewedBy').textContent=k.reviewedByName||'N/A';
let actions='';if(k.status==='Draft'||k.status==='RevisionRequired'){actions+=`<a href="/Risk/Edit/${k.riskId}" class="btn btn-primary btn-sm rounded-pill me-1"><i class="bi bi-pencil me-1"></i>Edit</a><button class="btn btn-success btn-sm rounded-pill" onclick="submitRisk()"><i class="bi bi-send me-1"></i>Submit</button>`}if(isAdmin&&k.status==='Approved'){actions+=`<button class="btn btn-dark btn-sm rounded-pill" onclick="closeRisk()"><i class="bi bi-lock me-1"></i>Close</button>`}document.getElementById('actionsBody').innerHTML=actions||'<p class="text-muted mb-0">No actions available</p>';
if(isAdmin&&(k.status==='Submitted'||k.status==='UnderReview')){document.getElementById('reviewCard').style.display=''}
if(k.history&&k.history.length){document.getElementById('historyBody').innerHTML=k.history.map(h=>`<div class="timeline-item"><div class="d-flex justify-content-between"><strong>${h.action||h.newStatus}</strong><small class="text-muted">${new Date(h.changedDate).toLocaleString()}</small></div><p class="mb-1"><span class="badge bg-secondary rounded-pill">${h.oldStatus||'—'}</span> → <span class="badge bg-primary rounded-pill">${h.newStatus}</span></p>${h.remarks?`<p class="text-muted mb-0 small">${h.remarks}</p>`:''}<small class="text-muted">by ${h.changedByName}</small><hr/></div>`).join('')}else{document.getElementById('historyBody').innerHTML='<p class="text-muted">No history</p>'}})}
function submitRisk(){apiCall('POST',`/api/risk/submit/${riskId}`).then(r=>{showToast(r.message,r.success?'success':'danger');if(r.success)loadRisk()})}
function closeRisk(){apiCall('POST',`/api/risk/close/${riskId}`).then(r=>{showToast(r.message,r.success?'success':'danger');if(r.success)loadRisk()})}
function review(action){const remarks=document.getElementById('rRemarks').value;apiCall('POST',`/api/risk/review/${riskId}`,{action,remarks}).then(r=>{showToast(r.message,r.success?'success':'danger');if(r.success)loadRisk()})}
document.addEventListener('DOMContentLoaded',loadRisk);
</script>}
