@{ ViewData["Title"] = "Risk Register"; }
<div class="d-flex justify-content-between align-items-center mb-4"><h5 class="mb-0">Risk Register</h5><a href="/Risk/Create" class="btn btn-primary rounded-pill"><i class="bi bi-plus-lg me-1"></i>Add Risk</a></div>
<div class="card mb-4"><div class="card-body"><div class="row g-2 align-items-end">
    <div class="col-md-2"><select class="form-select" id="fBU"><option value="">All BU</option></select></div>
    <div class="col-md-2"><select class="form-select" id="fFY"><option value="">All FY</option></select></div>
    <div class="col-md-2"><select class="form-select" id="fCat"><option value="">All Categories</option></select></div>
    <div class="col-md-2"><select class="form-select" id="fStat"><option value="">All Status</option><option>Draft</option><option>Submitted</option><option>UnderReview</option><option>Approved</option><option>Rejected</option><option>RevisionRequired</option><option>Closed</option></select></div>
    <div class="col-md-2"><input type="text" class="form-control" id="fSearch" placeholder="Search..."/></div>
    <div class="col-md-2"><button class="btn btn-outline-primary w-100" onclick="loadRisks()"><i class="bi bi-search me-1"></i>Search</button></div>
</div></div></div>
<div class="card"><div class="card-body"><div class="table-responsive"><table class="table table-hover"><thead><tr><th>ID</th><th>Title</th><th>BU</th><th>Category</th><th>Impact</th><th>Likelihood</th><th>Status</th><th>Actions</th></tr></thead><tbody id="riskBody"><tr><td colspan="8" class="text-center text-muted">Loading...</td></tr></tbody></table></div></div></div>
@section scripts {
<script>
const impactBadge={'High':'bg-danger','Medium':'bg-warning text-dark','Low':'bg-success'};
const statusBadge={'Draft':'bg-secondary','Submitted':'bg-primary','UnderReview':'bg-info','Approved':'bg-success','Rejected':'bg-danger','RevisionRequired':'bg-warning text-dark','Closed':'bg-dark'};
function loadRisks(){const b=document.getElementById('fBU').value,f=document.getElementById('fFY').value,c=document.getElementById('fCat').value,s=document.getElementById('fStat').value,q=document.getElementById('fSearch').value;apiCall('GET',`/api/risk/all?buId=${encodeURIComponent(b)}&fyId=${encodeURIComponent(f)}&riskCatId=${c}&status=${encodeURIComponent(s)}&search=${encodeURIComponent(q)}`).then(r=>{const tb=document.getElementById('riskBody');if(!r.success||!r.data?.length){tb.innerHTML='<tr><td colspan="8" class="text-center text-muted">No risks found</td></tr>';return}tb.innerHTML=r.data.map(k=>`<tr><td>${k.riskId}</td><td><a href="/Risk/Detail/${k.riskId}">${k.riskTitle}</a></td><td>${k.buName||k.buId||''}</td><td>${k.riskCatName||''}</td><td><span class="badge ${impactBadge[k.impactLevel]||'bg-secondary'} rounded-pill">${k.impactLevel}</span></td><td>${k.likelihood}</td><td><span class="badge ${statusBadge[k.status]||'bg-secondary'} rounded-pill">${k.status}</span></td><td><a href="/Risk/Detail/${k.riskId}" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>${k.status==='Draft'||k.status==='RevisionRequired'?`<a href="/Risk/Edit/${k.riskId}" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>`:''}</td></tr>`).join('')})}
function loadDropdowns(){apiCall('GET','/api/bu/dropdown').then(r=>{if(r.success)r.data.forEach(d=>{const o=document.createElement('option');o.value=d.value;o.text=d.text;document.getElementById('fBU').appendChild(o)})});apiCall('GET','/api/permission/fy/dropdown').then(r=>{if(r.success)r.data.forEach(d=>{const o=document.createElement('option');o.value=d.value;o.text=d.text;document.getElementById('fFY').appendChild(o)})});apiCall('GET','/api/riskcategory/dropdown').then(r=>{if(r.success)r.data.forEach(d=>{const o=document.createElement('option');o.value=d.riskCatId;o.text=d.riskCatName;document.getElementById('fCat').appendChild(o)})})}
document.addEventListener('DOMContentLoaded',()=>{loadDropdowns();loadRisks()});
</script>}
