@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Error - ERMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet"/>
    <style>body{font-family:'Inter',sans-serif;background:#f2f3f4;display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0;}.error-card{text-align:center;max-width:500px;padding:3rem;background:#fff;border-radius:16px;box-shadow:0 2px 20px rgba(0,0,0,.08)}.error-icon{font-size:4rem;color:#c0392b;margin-bottom:1rem}.error-title{font-size:1.5rem;font-weight:600;margin-bottom:.5rem;color:#2c3e50}.error-msg{color:#7f8c8d;margin-bottom:1.5rem}</style>
</head>
<body>
    <div class="error-card">
        <div class="error-icon">⚠️</div>
        <div class="error-title">Something went wrong</div>
        <p class="error-msg">An unexpected error occurred. Please try again later.</p>
        <a href="/Home/Dashboard" class="btn btn-primary">Back to Dashboard</a>
    </div>
</body>
</html>
