<header class="topnav" id="topnav">
    <div class="topnav-left">
        <button class="btn btn-link topnav-toggle" id="mobileToggle" type="button">
            <i class="bi bi-list"></i>
        </button>
        <h1 class="topnav-title">@(ViewData["Title"] ?? "ERMS")</h1>
    </div>
    <div class="topnav-right">
        <button class="btn btn-link theme-toggle" id="themeToggle" type="button" title="Toggle dark mode">
            <i class="bi bi-sun-fill" id="themeIcon"></i>
        </button>
        <div class="dropdown">
            <button class="btn btn-link dropdown-toggle user-dropdown" type="button" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><span class="dropdown-item-text fw-semibold">@(Context.Session.GetString("FullName") ?? "User")</span></li>
                <li><hr class="dropdown-divider"/></li>
                <li><a class="dropdown-item" href="/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
            </ul>
        </div>
    </div>
</header>
